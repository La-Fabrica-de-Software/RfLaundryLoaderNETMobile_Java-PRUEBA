package com.lafabricadesoftware.rfidlaundry.domain.model.ui

import androidx.room.PrimaryKey
import java.time.LocalDate
import java.util.Date

data class LecturaPrendaClienteSubCliente(
    @PrimaryKey(autoGenerate = true) val key: Int = 0,
    val idPrenda: Int = 0,
    val nombrePrenda: String = "",
    val talla: String = "",
    val tag: String = "",
    val isExiste: Boolean = false,
    val isBorrado: Boolean = false,
    val idCliente: Int = 0,
    val nombreCliente: String = "",
    val clienteBorrado: Boolean = false,
    val idSubCliente: Int = 0,
    val nombreSubCliente: String = "",
    val subClienteBorrado: Boolean = false,
    val idModeloPrenda: Int = 0,
    val nombreModeloPrenda: String = "",
    val idLastMov: Int = 0,
    val lastMovAntena: Int = 0,
    val lastMovFecha: String = "" //LocalDate? = null //LocalDate.now().atStartOfDay().toLocalDate().minusYears(100)


//    val isVerificado: Boolean = false,
//    var estado: PrendaLecturaTempEstadoType = PrendaLecturaTempEstadoType.NotVerified
) {}


