* msc.Borrado AS SubClienteBorrado, mp.id_ModeloPrenda AS IdModeloPrenda, mmp.Descripcion AS NombreModeloPrenda, mvp.Id AS IdLastMov,
* mvp.id_TipoAntena AS LastMovAntena, mvp.Fecha AS LastMovFecha
* */